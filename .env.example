# AgentLint runs the scanner and AI analysis entirely in the browser.
# There is NO server-side AI key — users bring their own key (Claude / GPT /
# Gemini / any OpenAI-compatible endpoint), stored only in their browser.
#
# Nothing below is required to run the scanner or AI briefing.

# Phase 4+ — leaderboard database (optional, only if you enable it)
DATABASE_URL=

# Phase 4+ — GitHub OAuth (NextAuth), only for the optional leaderboard
GITHUB_ID=
GITHUB_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=
